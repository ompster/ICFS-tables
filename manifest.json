{
  "manifest_version": 3,
  "name": "ICFS - Tables",
  "version": "2.0",
  "description": "Because some tables are impossible to read. Alternating row colours and hover highlighting for any HTML table.",
  "permissions": ["storage", "activeTab", "contextMenus", "tabs", "webNavigation"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["zebra.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
